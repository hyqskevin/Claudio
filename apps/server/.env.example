# ===== Server =====
SERVER_PORT=8080
DATABASE_URL=file:./data/ai-radio.sqlite

# ===== AI: Claude / MiniMax (Anthropic compatible) =====
# 填入任意一种：
#   官方 Anthropic：留空 CLAUDE_BASE_URL 走默认 https://api.anthropic.com
#   MiniMax (本方案)：CLAUDE_BASE_URL=https://api.minimaxi.com/anthropic
#   302.AI / OneAPI 等代理：CLAUDE_BASE_URL=https://your-proxy.example.com
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# ===== TTS: Fish Audio（默认） =====
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# ===== TTS: MiniMax（Phase 1.2 启用，优先于 Fish Audio） =====
MINIMAX_API_KEY=
MINIMAX_TTS_VOICE_ID=male-qn-qingse
MINIMAX_TTS_MODEL=speech-01-turbo

# ===== 网易云音乐 =====
# API 代理地址（hllqkb/Claudio 自带 ncm-server.mjs）
NCM_API_BASE_URL=http://localhost:3000
NCM_UID=

# 网易云账号 Cookie（用于「我的歌单」「每日推荐」等需要登录的接口）
# 也可在首次启动后通过前端设置页写入数据库 settings 表
# NETEASE_COOKIE=

# ===== 天气 =====
# 留空走 wttr.in（无需 key，但精度低）
# 填了就走 OpenWeather（精度高）
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Shanghai

# ===== 飞书日历（可选） =====
FEISHU_APP_ID=
FEISHU_APP_SECRET=
