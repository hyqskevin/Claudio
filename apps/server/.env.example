# ===== Server =====
SERVER_PORT=8080
DATABASE_URL=file:./data/ai-radio.sqlite

# ===== LLM Provider 1: MiniMax (国内, 默认主用) =====
# Anthropic-compatible protocol at api.minimaxi.com
# 已适配 MiniMax M3 模型
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M3

# ===== LLM Provider 2: Kimi / Moonshot (OpenAI-compatible, 备用) =====
# 当 MiniMax 不可用时自动 fallback 到 Kimi
# 申请: https://platform.moonshot.cn/
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# ===== LLM Provider 3: 官方 Anthropic (备选, 默认未启用) =====
# 如果要直连 Anthropic 而不是 MiniMax/Kimi，设置下面的变量并改 index.ts
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# ===== TTS: MiniMax (国内, Phase 1.2+ 优先) =====
# MiniMax API_KEY 同时用于 LLM 和 TTS（同一个账号）
MINIMAX_TTS_VOICE_ID=male-qn-qingse
MINIMAX_TTS_MODEL=speech-01-turbo
MINIMAX_TTS_ENDPOINT=https://api.minimaxi.com/v1/t2a_v2

# ===== TTS: Fish Audio (国际版, 备用) =====
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# ===== 网易云音乐 =====
# API 代理地址（hllqkb/Claudio 自带 ncm-server.mjs，端口 3000）
NCM_API_BASE_URL=http://localhost:3000
NCM_UID=

# 网易云账号 Cookie（用于「我的歌单」「每日推荐」等需要登录的接口）
# 也可在首次启动后通过前端设置页写入数据库 settings 表
# NETEASE_COOKIE=

# ===== 天气 =====
# 留空走 wttr.in（无需 key，但精度低）
# 填了就走 OpenWeather（精度高）
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Shanghai

# ===== 飞书日历（可选）=====
FEISHU_APP_ID=
FEISHU_APP_SECRET=